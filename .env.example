# Copy to .env and fill in.

# Anthropic SDK (optional — pipeline defaults to `claude -p` CLI which uses
# your Claude Code subscription, no separate API key needed).
# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-sonnet-4-6

# Gmail IMAP — used by src/gmail_codes.py to auto-read verification codes
# sent to your inbox during application submission.
# Setup:
#   1. Enable 2-Step Verification on your Google account
#   2. Generate App Password: https://myaccount.google.com/apppasswords
#   3. Paste below (16 chars, spaces OK — pipeline strips them)
# GMAIL_USER=you@gmail.com
# GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# JobSpy proxies (optional, if you hit rate limits)
# JOBSPY_PROXY=http://user:pass@host:port
